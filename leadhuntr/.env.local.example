# ============================================
# Supabase (REQUIRED)
# ============================================
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Google Gemini AI (REQUIRED — used to score leads)
# ============================================
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============================================
# Reddit (REQUIRED — public JSON API, no credentials)
# ============================================
# LeadHuntr uses reddit.com/r/{sub}/new.json — no OAuth needed.
# Only the User-Agent is sent. Keep it descriptive.
REDDIT_USER_AGENT=LeadHuntr/1.0

# ============================================
# App (REQUIRED)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Any long random string. Used to authorize Vercel cron calls.
CRON_SECRET=change-me-to-a-long-random-string

# ============================================
# Stripe (OPTIONAL — only needed for paid plans)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ============================================
# Resend (OPTIONAL — only needed for email alerts)
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@leadhuntr.com

# ============================================
# Upstash Redis (OPTIONAL — rate limiting; no-op if absent)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
